{
  "routes": [
    { "route": "/obiavi",            "rewrite": "/index.html" },
    { "route": "/obiavi/motori*",    "rewrite": "/index.html" },
    { "route": "/obiavi/ekipirovka*","rewrite": "/index.html" },
